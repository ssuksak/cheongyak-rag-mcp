# 청약 RAG MCP Server Configuration

# 공공데이터포털 API 키 (data.go.kr에서 발급, 선택)
DATA_GO_KR_API_KEY=

# OpenAI API (RAG 답변용, 선택)
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1

# 임베딩 모델 (기본: 한국어 최적화)
EMBEDDING_MODEL=jhgan/ko-sroberta-multitask

# ChromaDB 설정
CHROMA_PERSIST_DIR=./data/chroma_db

# 문서 경로 (PDF/HWP 공고문)
DOCUMENTS_DIR=./data/documents

# 캐시 TTL (분)
CACHE_TTL_MINUTES=30

# RAG 설정
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
SEARCH_TOP_K=5
